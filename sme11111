    <!-- SCRIPT: core application + admin module -->
    <script>
        // Default pricing data (same structure) with persistence support
        const DEFAULT_PRICING = {
            almaty: [
                { name: "АИ-92", price: 245, trend: "+1.2%", status: "up", cat: "auto", vol: "35% көлем" },
                { name: "АИ-95", price: 275, trend: "+0.8%", status: "up", cat: "auto", vol: "25% көлем" },
                { name: "Дизель (ДТ)", price: 320, trend: "+2.4%", status: "up", cat: "auto", vol: "30% көлем" },
                { name: "JET A-1", price: 410, trend: "-0.6%", status: "down", cat: "avia", vol: "15% көлем" },
                { name: "РТ керосин", price: 395, trend: "+0.3%", status: "up", cat: "avia", vol: "10% көлем" }
            ],
            astana: [
                { name: "АИ-92", price: 244, trend: "+1.0%", status: "up", cat: "auto", vol: "32% көлем" },
                { name: "АИ-95", price: 274, trend: "+0.7%", status: "up", cat: "auto", vol: "28% көлем" },
                { name: "Дизель (ДТ)", price: 319, trend: "+2.2%", status: "up", cat: "auto", vol: "29% көлем" },
                { name: "JET A-1", price: 409, trend: "-0.5%", status: "down", cat: "avia", vol: "11% көлем" }
            ],
            shymkent: [
                { name: "АИ-92", price: 242, trend: "+0.9%", status: "up", cat: "auto", vol: "18% көлем" },
                { name: "АИ-95", price: 272, trend: "+0.6%", status: "up", cat: "auto", vol: "16% көлем" },
                { name: "Дизель (ДТ)", price: 318, trend: "+2.1%", status: "up", cat: "auto", vol: "20% көлем" }
            ],
            atyrau: [
                { name: "JET A-1", price: 408, trend: "-0.4%", status: "down", cat: "avia", vol: "12% көлем" }
            ]
        };

        // Load from localStorage or use defaults
        function loadPricing() {
            try {
                const json = localStorage.getItem('navarro_pricing_v1');
                if (json) return JSON.parse(json);
            } catch (e) { console.warn('Failed parsing pricing from localStorage', e); }
            return structuredClone(DEFAULT_PRICING);
        }

        function savePricing(data) {
            localStorage.setItem('navarro_pricing_v1', JSON.stringify(data));
            logAdmin('Сақталды: баға кестесі жергілікті сақтауға жазылды.');
            updateAdminStats();
        }

        // Admin state
        let pricingData = loadPricing();
        let adminAuth = { loggedIn: false, user: null };

        // Simple demo users (in real app use server-side storage)
        const DEMO_USERS = [
            { email: 'admin@navarro-trade.kz', name: 'Administrator', role: 'admin' },
            { email: 'user1@example.com', name: 'Client One', role: 'buyer' },
        ];

        // Mock logs
        const adminLogs = [];
        function logAdmin(msg) { adminLogs.unshift({ t: new Date().toISOString(), m: msg }); renderAdminLogs(); }

        // INIT
        document.addEventListener('DOMContentLoaded', () => {
            renderPricesGrid();
            populateAdminRegions();
            updateAdminStats();
        });

        // NAVIGATION
        function switchTab(tabName) {
            ['sec-home','sec-prices','sec-company'].forEach(id => document.getElementById(id).classList.add('hidden'));
            document.getElementById(`sec-${tabName}`).classList.remove('hidden');
            document.querySelectorAll('nav button[id^="tab-"]').forEach(b=>b.classList.remove('bg-white/10'));
            document.getElementById(`tab-${tabName}`).classList.add('bg-white/10');
            if (tabName === 'prices') renderPricesGrid();
        }

        function toggleMobileMenu(show) {
            const m = document.getElementById('mobile-menu');
            if (show) m.classList.remove('translate-x-full'); else m.classList.add('translate-x-full');
        }

        // FRONTEND RENDERERS
        function renderPricesGrid() {
            const container = document.getElementById('prices-grid');
            container.innerHTML = '';
            Object.keys(pricingData).forEach(region => {
                pricingData[region].forEach(item => {
                    const card = document.createElement('div');
                    card.className = 'p-4 bg-white/[0.02] border border-white/5 rounded-2xl';
                    card.innerHTML = `
                        <div class="flex justify-between">
                            <div>
                                <div class="text-sm font-semibold">${item.name}</div>
                                <div class="text-xs text-gray-400">${region}</div>
                            </div>
                            <div class="text-right">
                                <div class="text-lg font-black">${item.price} т/л</div>
                                <div class="text-xs ${item.status==='up'?'text-green-400':'text-red-400'}">${item.trend}</div>
                            </div>
                        </div>
                    `;
                    container.appendChild(card);
                });
            });
        }

        // ----------------- ADMIN MODULE ------------------
        function showLogin(show) {
            const modal = document.getElementById('login-modal');
            if (show) modal.classList.remove('hidden'); else modal.classList.add('hidden');
        }

        function fillDemoAdmin(){
            document.getElementById('admin-email').value = 'admin@navarro-trade.kz';
            document.getElementById('admin-pass').value = 'Admin123!';
        }

        function adminAuthenticate(){
            const email = document.getElementById('admin-email').value.trim();
            const pass = document.getElementById('admin-pass').value;
            const err = document.getElementById('login-error');
            err.classList.add('hidden');

            // Demo authentication
            if (email === 'admin@navarro-trade.kz' && pass === 'Admin123!'){
                adminAuth = { loggedIn: true, user: { email: email, name: 'Administrator', role: 'admin' } };
                localStorage.setItem('navarro_admin_session', JSON.stringify({ email }));
                showLogin(false);
                openAdmin();
                logAdmin('Admin кірді: ' + email);
            } else {
                err.textContent = 'Кіру сәтсіз: деректер дұрыс емес.';
                err.classList.remove('hidden');
                logAdmin('Кіру сәтсіз: ' + email);
            }
        }

        function openAdmin(){
            document.getElementById('admin-dashboard').classList.remove('hidden');
            openAdminSection('dashboard');
            renderAdminUsers();
            renderAdminPrices();
            renderAdminLogs();
        }

        function adminLogout(){
            adminAuth = { loggedIn: false, user: null };
            localStorage.removeItem('navarro_admin_session');
            document.getElementById('admin-dashboard').classList.add('hidden');
            logAdmin('Admin шықты.');
        }

        function openAdminSection(id){
            ['dashboard','prices','users','logs'].forEach(s => document.getElementById('admin-section-'+s).classList.add('hidden'));
            document.getElementById('admin-section-'+id).classList.remove('hidden');
            // update active tab style
            ['admin-tab-dashboard','admin-tab-prices','admin-tab-users','admin-tab-logs'].forEach(idb=>{const el=document.getElementById(idb); if(el) el.classList.remove('bg-white/10');});
            const activeBtn = document.getElementById('admin-tab-'+id); if(activeBtn) activeBtn.classList.add('bg-white/10');
        }

        function populateAdminRegions(){
            const sel = document.getElementById('admin-select-region');
            if (!sel) return;
            sel.innerHTML = '';
            Object.keys(pricingData).forEach(r => {
                const opt = document.createElement('option'); opt.value = r; opt.textContent = r; sel.appendChild(opt);
            });
        }

        function updateAdminStats(){
            document.getElementById('admin-region-count').textContent = Object.keys(pricingData).length;
            const total = Object.values(pricingData).reduce((s, arr) => s + arr.length, 0);
            document.getElementById('admin-products-count').textContent = total;
            document.getElementById('admin-saved-status').textContent = localStorage.getItem('navarro_pricing_v1') ? 'Local' : 'Defaults';
        }

        // Admin: render prices list
        function renderAdminPrices(){
            populateAdminRegions();
            const sel = document.getElementById('admin-select-region');
            const region = sel ? sel.value : Object.keys(pricingData)[0];
            const list = pricingData[region] || [];
            const container = document.getElementById('admin-prices-list');
            if (!container) return;
            container.innerHTML = '';
            list.forEach((item, idx) => {
                const el = document.createElement('div');
                el.className = 'p-4 bg-white/[0.02] rounded-2xl border border-white/5 flex flex-col justify-between';
                el.innerHTML = `
                    <div>
                        <div class="text-sm font-semibold">${item.name}</div>
                        <div class="text-xs text-gray-400">${item.cat} · ${region}</div>
                    </div>
                    <div class="mt-4 flex items-center justify-between">
                        <div class="text-lg font-black">${item.price} т/л</div>
                        <div class="flex gap-2">
                            <button onclick="editPrice('${region}', ${idx})" class="bg-white/5 px-3 py-1 rounded-md">Өңдеу</button>
                            <button onclick="deletePrice('${region}', ${idx})" class="bg-red-600 px-3 py-1 rounded-md">Жою</button>
                        </div>
                    </div>
                `;
                container.appendChild(el);
            });
            updateAdminStats();
        }

        function showAddPriceForm(){
            const form = document.getElementById('admin-price-form');
            document.getElementById('admin-price-form-title').textContent = 'Жаңа өнім қосу';
            document.getElementById('admin-price-form-index').value = '';
            document.getElementById('admin-price-name').value = '';
            document.getElementById('admin-price-value').value = '';
            document.getElementById('admin-price-cat').value = 'auto';
            document.getElementById('admin-price-status').value = 'up';
            form.classList.remove('hidden');
        }

        function closePriceForm(){ document.getElementById('admin-price-form').classList.add('hidden'); }

        function savePriceForm(){
            const idx = document.getElementById('admin-price-form-index').value;
            const name = document.getElementById('admin-price-name').value.trim();
            const price = Number(document.getElementById('admin-price-value').value);
            const cat = document.getElementById('admin-price-cat').value;
            const status = document.getElementById('admin-price-status').value;
            const region = document.getElementById('admin-select-region').value;
            if (!name || !price || !region) return alert('Барлық өрістер толтырылсын');
            const rec = { name, price, trend: (status==='up'?'+0.0%':'-0.0%'), status, cat, vol: '0% көлем' };
            if (idx === '') {
                pricingData[region].push(rec);
                logAdmin(`Өнім қосылды: ${name} (${region})`);
            } else {
                pricingData[region][Number(idx)] = rec;
                logAdmin(`Өнім өңделді: ${name} (${region})`);
            }
            savePricing(pricingData);
            renderAdminPrices();
            renderPricesGrid();
            closePriceForm();
        }

        function editPrice(region, idx){
            const rec = pricingData[region][idx];
            document.getElementById('admin-price-form-title').textContent = 'Өнімді өңдеу';
            document.getElementById('admin-price-form-index').value = idx;
            document.getElementById('admin-price-name').value = rec.name;
            document.getElementById('admin-price-value').value = rec.price;
            document.getElementById('admin-price-cat').value = rec.cat;
            document.getElementById('admin-price-status').value = rec.status;
            document.getElementById('admin-price-form').classList.remove('hidden');
        }

        function deletePrice(region, idx){
            if (!confirm('Өнімі шын мәнінде жойғыңыз келе ме?')) return;
            const name = pricingData[region][idx].name;
            pricingData[region].splice(idx,1);
            savePricing(pricingData);
            renderAdminPrices();
            renderPricesGrid();
            logAdmin('Өнім жойылды: ' + name);
        }

        // Admin: users
        function renderAdminUsers(){
            const el = document.getElementById('admin-users-list');
            if(!el) return;
            el.innerHTML = '';
            DEMO_USERS.forEach(u => {
                const item = document.createElement('div');
                item.className = 'p-4 bg-white/[0.02] rounded-2xl border border-white/5';
                item.innerHTML = `<div class="font-semibold">${u.name}</div><div class="text-xs text-gray-400">${u.email} · ${u.role}</div>`;
                el.appendChild(item);
            });
        }

        // Admin: logs
        function renderAdminLogs(){
            const el = document.getElementById('admin-logs');
            if(!el) return;
            el.innerHTML = adminLogs.map(l => `<div>[${l.t}] ${l.m}</div>`).join('');
        }

        function renderAdminLogs(){
            const el = document.getElementById('admin-logs');
            if(!el) return;
            el.innerHTML = adminLogs.map(l => `<div class="py-1 border-b border-white/5">[${l.t}] ${l.m}</div>`).join('');
        }

        // Admin export/import
        function adminExport(){
            const data = { pricing: pricingData, exportedAt: new Date().toISOString() };
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a'); a.href = url; a.download = 'navarro_pricing_export.json'; a.click();
            URL.revokeObjectURL(url);
            logAdmin('Экспорт жасалды');
        }

        function adminImportPrompt(){
            const input = document.createElement('input'); input.type = 'file'; input.accept = 'application/json';
            input.onchange = (e)=>{
                const f = e.target.files[0]; if(!f) return;
                const reader = new FileReader();
                reader.onload = ()=>{
                    try{
                        const data = JSON.parse(reader.result);
                        if (data.pricing) {
                            pricingData = data.pricing;
                            savePricing(pricingData);
                            renderAdminPrices(); renderPricesGrid();
                            logAdmin('Импорттан кейін жүктелді');
                            alert('Импорт сәтті болды');
                        } else alert('Файл жарамсыз: pricing объектісін таппады.');
                    }catch(err){ alert('Импортта қате: ' + err.message); }
                };
                reader.readAsText(f);
            };
            input.click();
        }

        function resetPricingToDefaults(confirmIt){
            if (confirmIt && !confirm('Барлық жергілікті өзгерістер жойылады. Жалғастырасыз ба?')) return;
            pricingData = structuredClone(DEFAULT_PRICING);
            savePricing(pricingData);
            renderAdminPrices(); renderPricesGrid();
            logAdmin('Параметрлер бастапқы күйге қайтарылды');
        }

        // Utility: simple local log renderer
        function renderAdminLogs(){
            const el = document.getElementById('admin-logs');
            if(!el) return;
            el.innerHTML = adminLogs.map(l => `<div class="py-2 border-b border-white/5 text-xs">[${l.t}] ${l.m}</div>`).join('');
        }

    </script>
</body>
</html>
