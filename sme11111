    <!-- JAVASCRIPT LOGIC -->
    <script>
        // Mock data base matching the screenshot states
        const pricingData = {
            almaty: [
                { name: "АИ-92", price: "245", trend: "+1.2%", status: "up", cat: "auto", vol: "35% көлем" },
                { name: "АИ-95", price: "275", trend: "+0.8%", status: "up", cat: "auto", vol: "25% көлем" },
                { name: "Дизель (ДТ)", price: "320", trend: "+2.4%", status: "up", cat: "auto", vol: "30% көлем" },
                { name: "JET A-1", price: "410", trend: "-0.6%", status: "down", cat: "avia", vol: "15% көлем" },
                { name: "РТ керосин", price: "395", trend: "+0.3%", status: "up", cat: "avia", vol: "10% көлем" }
            ],
            astana: [
                { name: "АИ-92", price: "244", trend: "+1.0%", status: "up", cat: "auto", vol: "32% көлем" },
                { name: "АИ-95", price: "274", trend: "+0.7%", status: "up", cat: "auto", vol: "28% көлем" },
                { name: "Дизель (ДТ)", price: "319", trend: "+2.2%", status: "up", cat: "auto", vol: "29% көлем" },
                { name: "JET A-1", price: "409", trend: "-0.5%", status: "down", cat: "avia", vol: "11% көлем" }
            ],
            shymkent: [
                { name: "АИ-92", price: "242", trend: "+0.9%", status: "up", cat: "auto", vol: "18% көлем" },
                { name: "АИ-95", price: "272", trend: "+0.6%", status: "up", cat: "auto", vol: "16% көлем" },
                { name: "Дизель (ДТ)", price: "318", trend: "+2.1%", status: "up", cat: "auto", vol: "20% көлем" }
            ],
            atyrau: [
                { name: "JET A-1", price: "408", trend: "-0.4%", status: "down", cat: "avia", vol: "12% көлем" }
            ]
        };

        // State managers
        let activeLiveCity = 'almaty';
        let activeFilterCity = 'almaty';
        let activeFilterCategory = 'all';

        // Initialize view
        document.addEventListener('DOMContentLoaded', () => {
            renderLivePrices();
            renderPricesGrid();
        });

        // Tab Switcher
        function switchTab(tabName) {
            // Hide all
            document.getElementById('sec-home').classList.add('hidden');
            document.getElementById('sec-prices').classList.add('hidden');
            document.getElementById('sec-company').classList.add('hidden');
            
            // Remove active style from tabs
            document.getElementById('tab-home').className = "px-5 py-2 rounded-full font-medium transition-colors text-gray-400 hover:text-white";
            document.getElementById('tab-prices').className = "px-5 py-2 rounded-full font-medium transition-colors text-gray-400 hover:text-white";
            document.getElementById('tab-company').className = "px-5 py-2 rounded-full font-medium transition-colors text-gray-400 hover:text-white";

            // Show and set active
            document.getElementById(`sec-${tabName}`).classList.remove('hidden');
            document.getElementById(`tab-${tabName}`).className = "px-5 py-2 rounded-full font-medium transition-colors bg-white/10 text-white";
        }

        // Live prices widget selector
        function setLiveCity(city) {
            activeLiveCity = city;
            ['almaty', 'astana', 'shymkent', 'atyrau'].forEach(c => {
                const btn = document.getElementById(`live-btn-${c}`);
                if (c === city) {
                    btn.className = "flex-1 py-1.5 px-3 rounded-lg font-medium bg-blue-600 text-white transition-all";
                } else {
                    btn.className = "flex-1 py-1.5 px-3 rounded-lg font-medium text-gray-400 hover:text-white transition-all";
                }
            });
            renderLivePrices();
        }

        function renderLivePrices() {
            const list = pricingData[activeLiveCity];
            const container = document.getElementById('live-prices-container');
            container.innerHTML = '';

            list.forEach(item => {
                const isUp = item.status === 'up';
                const trendColor = isUp ? 'text-green-500 bg-green-500/10' : 'text-red-500 bg-red-500/10';
                
                const html = `
                    <div class="flex items-center justify-between border-b border-white/5 pb-3">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg bg-white/5 border border-white/5 flex items-center justify-center text-xs text-gray-400">
                                ${item.cat === 'auto' ? '⛽' : '✈️'}
                            </div>
                            <div>
                                <span class="font-semibold text-sm block">${item.name}</span>
                                <span class="text-[10px] text-gray-500 capitalize block">${activeLiveCity}</span>
                            </div>
                        </div>
                        <div class="text-right">
                            <span class="font-black text-base block">${item.price}.00 <span class="text-[10px] text-gray-400 font-normal">т/л</span></span>
                            <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-md ${trendColor}">${item.trend}</span>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });
        }

        // Filter Page Functions
        function setFilterCity(city) {
            activeFilterCity = city;
            ['almaty', 'astana', 'shymkent', 'atyrau'].forEach(c => {
                const btn = document.getElementById(`filter-city-${c}`);
                if (c === city) {
                    btn.className = "px-5 py-2.5 rounded-full border text-sm font-semibold transition-all border-blue-600 bg-blue-600 text-white flex items-center gap-2";
                } else {
                    btn.className = "px-5 py-2.5 rounded-full border text-sm font-semibold transition-all border-white/10 bg-white/5 text-gray-400 hover:text-white flex items-center gap-2";
                }
            });
            renderPricesGrid();
        }

        function setFilterCategory(cat) {
            activeFilterCategory = cat;
            ['all', 'auto', 'avia'].forEach(c => {
                const btn = document.getElementById(`filter-cat-${c}`);
                if (c === cat) {
                    btn.className = "px-4 py-1.5 rounded-full text-xs font-semibold bg-white/10 text-white transition-all";
                } else {
                    btn.className = "px-4 py-1.5 rounded-full text-xs font-semibold text-gray-400 hover:text-white transition-all";
                }
            });
            renderPricesGrid();
        }

        function renderPricesGrid() {
            const list = pricingData[activeFilterCity];
            const container = document.getElementById('prices-grid');
            container.innerHTML = '';

            const filtered = list.filter(item => {
                if (activeFilterCategory === 'all') return true;
                return item.cat === activeFilterCategory;
            });

            if (filtered.length === 0) {
                container.innerHTML = '<div class="col-span-3 text-center text-gray-500 py-12">Таңдалған санат бойынша өнімдер табылмады.</div>';
                return;
            }

            filtered.forEach(item => {
                const isUp = item.status === 'up';
                const trendColor = isUp ? 'text-green-500 bg-green-500/10' : 'text-red-500 bg-red-500/10';
                
                // SVG dynamic path for sparkline based on up/down status
                const graphPath = isUp 
                    ? "M10 50 Q 80 10, 160 40 T 320 30" 
                    : "M10 20 Q 80 50, 160 15 T 320 45";
                const graphColor = isUp ? "url(#green-glow)" : "url(#red-glow)";
                const graphStroke = isUp ? "#10b981" : "#ef4444";

                const html = `
                    <div class="border border-white/5 bg-slate-900/30 backdrop-blur-md rounded-3xl p-6 shadow-lg hover:border-white/10 transition-all flex flex-col justify-between h-64">
                        <div>
                            <div class="flex items-center justify-between mb-4">
                                <span class="text-xs text-gray-500 flex items-center gap-1">
                                    ${item.cat === 'auto' ? '⛽' : '✈️'} ${item.name}
                                </span>
                                <span class="text-xs font-bold px-2 py-0.5 rounded-md ${trendColor}">${item.trend}</span>
                            </div>
                            <div class="flex items-baseline gap-1.5">
                                <span class="text-4xl font-black">${item.price}</span>
                                <span class="text-xs text-gray-400 font-medium">т/л</span>
                            </div>
                            <span class="text-[10px] text-gray-500 block capitalize mt-1">📍 ${activeFilterCity}</span>
                        </div>

                        <!-- Sparkline graphic -->
                        <div class="w-full h-16 my-2">
                            <svg class="w-full h-full" viewBox="0 0 320 60" fill="none" preserveAspectRatio="none">
                                <defs>
                                    <linearGradient id="green-glow" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="#10b981" stop-opacity="0.25"/>
                                        <stop offset="100%" stop-color="#10b981" stop-opacity="0"/>
                                    </linearGradient>
                                    <linearGradient id="red-glow" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="#ef4444" stop-opacity="0.25"/>
                                        <stop offset="100%" stop-color="#ef4444" stop-opacity="0"/>
                                    </linearGradient>
                                </defs>
                                <path d="${graphPath} L 320 60 L 10 60 Z" fill="${graphColor}" />
                                <path d="${graphPath}" stroke="${graphStroke}" stroke-width="2.5" stroke-linecap="round"/>
                            </svg>
                        </div>

                        <div class="flex items-center justify-between border-t border-white/5 pt-3 text-[10px] text-gray-500">
                            <span>14 күндік динамика</span>
                            <span>${item.vol}</span>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });
        }

        // Toggle Dialog (Modal)
        function toggleModal(show) {
            const modal = document.getElementById('login-modal');
            if (show) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }

        // Mobile Menu Drawer Toggle
        function toggleMobileMenu(show) {
            const menu = document.getElementById('mobile-menu');
            if (show) {
                menu.classList.remove('translate-x-full');
            } else {
                menu.classList.add('translate-x-full');
            }
        }
    </script>
</body>
</html>
